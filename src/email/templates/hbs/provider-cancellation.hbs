<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Réservation annulée - Rose des Vins</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f5f5; line-height: 1.6;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5; padding: 20px;">
    <tr>
      <td align="center">
        <table width="650" cellpadding="0" cellspacing="0" border="0" style="max-width: 650px; background-color: white; border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);">

          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #2d5f44 0%, #245038 100%); padding: 30px; text-align: center; color: white; border-radius: 12px 12px 0 0;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding: 20px 25px;">
                    <img src="{{appLogoUrl}}" alt="Rose des Vins Logo" width="120" style="max-width: 120px; height: auto; display: block; margin: 0 auto;">
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Main Content -->
          <tr>
            <td style="padding: 45px 35px; background: linear-gradient(to bottom, #fffef7 0%, #fefdf5 100%);">

              <!-- Greeting -->
              <p style="color: #333; font-size: 18px; margin: 0 0 30px 0; text-align: center; text-transform: capitalize;">Bonjour {{providerName}},</p>

              <!-- Title -->
              <h1 style="color: #dc3545; font-size: 28px; font-weight: 700; text-align: center; margin: 0 0 35px 0; letter-spacing: -0.5px;">Une réservation a été annulée</h1>

              <!-- Cancellation Notice -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 35px;">
                <tr>
                  <td style="background-color: #f8d7da; border: 2px solid #dc3545; border-radius: 12px; padding: 25px; text-align: center;">
                    <div style="color: #dc3545; font-size: 18px; font-weight: 600; margin-bottom: 10px;">❌ Annulation confirmée</div>
                    <p style="color: #721c24; font-size: 14px; margin: 0;">Le client a annulé sa réservation. Voici le récapitulatif ci-dessous.</p>
                  </td>
                </tr>
              </table>

              <!-- Customer Info Card -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 25px;">
                <tr>
                  <td style="background: linear-gradient(135deg, #fdf0f0 0%, #fff5f5 100%); border: 1px solid rgba(220,53,69,0.3); border-radius: 12px; padding: 20px; text-align: center;">
                    <p style="color: #721c24; font-size: 16px; margin: 0 0 6px 0;"><strong>{{customerName}}</strong></p>
                    <p style="color: #721c24; font-size: 14px; margin: 0;">{{customerEmail}}</p>
                  </td>
                </tr>
              </table>

              <!-- Reservation Details Card -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: white; border-radius: 12px; padding: 35px; margin-bottom: 35px; box-shadow: 0 6px 30px rgba(0,0,0,0.08); border: 1px solid rgba(220,53,69,0.1);">

                <!-- Domain Name -->
                <tr>
                  <td style="padding-bottom: 25px;">
                    <h2 style="color: #333; font-size: 22px; font-weight: 600; text-align: center; margin: 0;">{{domainName}}</h2>
                  </td>
                </tr>

                <!-- Details Grid -->
                <tr>
                  <td>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <!-- Image -->
                        <td width="50%" style="text-align: center; vertical-align: top; padding-right: 25px;">
                          <img src="{{serviceBannerUrl}}" alt="{{serviceName}}" width="180" height="180" style="border-radius: 50%; object-fit: cover; box-shadow: 0 4px 15px rgba(0,0,0,0.2); display: block; margin: 0 auto; filter: grayscale(50%);">
                        </td>

                        <!-- Info -->
                        <td width="50%" style="vertical-align: top;">

                          <!-- Date / Time + Language -->
                          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 18px;">
                            <tr>
                              <td width="50%" style="padding-right: 15px; vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/clock" alt="Clock" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 12px; white-space: nowrap;">{{eventDate}} - {{eventTime}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                              <td width="50%" style="vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/language" alt="Language" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 12px; white-space: nowrap;">{{selectedLanguage}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                            </tr>
                          </table>

                          <!-- Service + Duration -->
                          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 18px;">
                            <tr>
                              <td width="50%" style="padding-right: 15px; vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/type-of-experience" alt="Experience" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 11px;">{{serviceName}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                              <td width="50%" style="vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/clock" alt="Duration" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 12px; white-space: nowrap;">{{eventDuration}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                            </tr>
                          </table>

                          <!-- Participants + Wines -->
                          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 18px;">
                            <tr>
                              <td width="50%" style="padding-right: 15px; vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/user" alt="Participants" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 12px; white-space: nowrap;">{{participantsAdults}} adulte{{#if (gt participantsAdults 1)}}s{{/if}}{{#if (gt participantsChildren 0)}} + {{participantsChildren}} enfant{{#if (gt participantsChildren 1)}}s{{/if}}{{/if}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                              <td width="50%" style="vertical-align: top;">
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/wine-glass" alt="Wine" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #444; font-weight: 500; font-size: 12px; white-space: nowrap;">{{numberOfWinesTasted}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                            </tr>
                          </table>

                          <!-- Payment -->
                          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top: 20px;">
                            <tr>
                              <td>
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/euro-currency-symbol" alt="Payment" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #666; font-weight: 500; font-size: 11px;">{{paymentMethod}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                            </tr>
                          </table>

                          <!-- Total Price -->
                          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top: 1px solid #e0e0e0; padding-top: 15px; margin-top: 20px;">
                            <tr>
                              <td>
                                <table cellpadding="0" cellspacing="0" border="0">
                                  <tr>
                                    <td style="vertical-align: middle; padding-right: 8px;">
                                      <img src="https://api.rosedesvins.co/v1/web/image/total%20amount" alt="Price" width="16" height="16" style="display: block;">
                                    </td>
                                    <td style="vertical-align: middle;">
                                      <span style="color: #dc3545; font-weight: 700; font-size: 16px;">{{totalPrice}}</span>
                                    </td>
                                  </tr>
                                </table>
                              </td>
                            </tr>
                          </table>

                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                {{#if additionalNotes}}
                <!-- Additional Notes -->
                <tr>
                  <td style="padding-top: 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="background-color: #f8f9fa; border-radius: 8px; padding: 15px;">
                          <strong style="color: #dc3545;">Notes particulières :</strong><br>
                          <span style="color: #666;">{{additionalNotes}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/if}}

              </table>

              <!-- Domain Address -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #e0e0e0;">
                <tr>
                  <td style="color: #999; font-size: 14px; text-align: center;">
                    <strong>{{domainName}}</strong>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #3A7B59; padding: 30px 20px; text-align: center; color: white; border-radius: 0 0 12px 12px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 500px; margin: 0 auto;">
                <tr>
                  <td width="70%" style="text-align: left; vertical-align: middle;">
                    <table cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="width: 50px; vertical-align: middle; padding-right: 15px;">
                          <div style="width: 40px; height: 40px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; padding: 5px; box-sizing: border-box;">
                            <img src="{{appLogoUrl}}" alt="Rose des Vins Logo" width="30" height="30" style="display: block;">
                          </div>
                        </td>
                        <td style="vertical-align: middle;">
                          <div style="font-size: 18px; font-weight: 500; color: white; margin: 0;">Rose des Vins</div>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td width="30%" style="text-align: right; vertical-align: middle;">
                    <a href="https://rosedesvins.co/#contact" style="font-size: 16px; font-weight: 500; color: white; text-decoration: none;">Contact</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
